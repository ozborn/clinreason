property_value: IAO:0000112 "Patient admitted to ICU" xsd:string
property_value: IAO:0000232 "Does not exist in OMOP, admission is specific for inpatients or other facility types." xsd:string

[Term]
id: CLCO:0000011
name: is subsequent to
def: "Statement indicating that an intervention is followed by an intervention or assessment" []
