format-version: 1.2
data-version: releases/2026-05-15
ontology: clco
property_value: http://purl.org/dc/elements/1.1/creator "James J. Cimino" xsd:string
property_value: http://purl.org/dc/elements/1.1/creator "John D. Osborne" xsd:string
property_value: http://purl.org/dc/elements/1.1/creator "Tiago K. Colicchio" xsd:string
property_value: http://purl.org/dc/elements/1.1/description "An ontology for representing clinical reasoning context, including diagnostic workflows, therapeutic decision-making, and the clinician interpretations and decisions that surround patient care but are not well captured by problem-focused EHR systems or terminologies such as SNOMED CT." xsd:string
property_value: http://purl.org/dc/elements/1.1/title "Clinical Context Ontology" xsd:string
property_value: http://purl.org/dc/terms/creator https://orcid.org/0000-0002-0851-1150
property_value: http://purl.org/dc/terms/creator https://orcid.org/0000-0003-3405-1538
property_value: http://purl.org/dc/terms/creator https://orcid.org/0000-0003-4101-1622
property_value: http://purl.org/dc/terms/license http://creativecommons.org/licenses/by/4.0/
property_value: owl:versionInfo "2025-09-05" xsd:string
property_value: owl:versionInfo "2026-05-15" xsd:string

[Term]
id: BFO:0000001
name: entity
def: "An entity is anything that exists or has existed or will exist." []

[Term]
id: CLCO:0000002
name: is transferred to
def: "Destination of patient transference" []
xref: LOINC:LP203270-6
xref: OMOP_CONCEPT_ID:1014654
is_a: CLCO:0000058 ! has setting
relationship: CLCO:0002502 CLCO:0000110 ! has subject patient

[Term]
id: CLCO:0000003
name: clinical administration
def: "Clinical processes relation to administration." []
is_a: CLCO:0000057 ! clinical association
property_value: IAO:0000232 "Do not instantiate." xsd:string

[Term]
id: CLCO:0000005
name: clinical decision
def: "A clinical association representing a decision made during patient care, such as a treatment plan, referral, or diagnostic strategy." []
is_a: CLCO:0000057 ! clinical association

[Term]
id: CLCO:0000006
name: clinical explanation
def: "A clinical reason explaining the reasoning behind a treatment, intervention, condition or medical statement." []
is_a: CLCO:0000057 ! clinical association

[Term]
id: CLCO:0000007
name: has action
def: "A member of the clinical team has a specific action" []
