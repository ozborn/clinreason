xref: SNOMED:410671006
is_a: CLCO:0000057 ! clinical association
relationship: CLCO:0002501 CLCO:0000103 ! has object time
property_value: IAO:0000112 "She has an appointment with Dr. PHI tomorrow" xsd:string
