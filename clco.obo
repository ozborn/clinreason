relationship: CLCO:0002502 CLCO:0000102 ! has subject intervention
property_value: IAO:0000112 "Here for packing and splint removal after recent discharge from rehab" xsd:string
property_value: IAO:0000232 "Used to be \"is followed by\" but this causes confusion when following refers to a particular clilnician responsible for a patient's care" xsd:string

[Term]
id: CLCO:0000012
name: is performed by
def: "Report of provider performing an intervention or assessment" []
