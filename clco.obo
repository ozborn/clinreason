relationship: CLCO:0002502 CLCO:0000108 ! has subject clinician
property_value: IAO:0000112 "upload OSH CT chest pulmonary vein protocol" xsd:string

[Term]
id: CLCO:0000010
name: is admitted
def: "Statement indicating that the patient was admitted to a specific setting" []
