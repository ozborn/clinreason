            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000112>Severe abdominal pain; mild hearing loss.</obo:IAO_0000112>
        <obo:IAO_0000115>A finding association specifying the severity or intensity of a finding or condition.</obo:IAO_0000115>
        <rdfs:label>has severity</rdfs:label>
    </owl:Class>
    


