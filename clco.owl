        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/CLCO_0000100"/>
        <obo:IAO_0000115>An intervention to treat or diagnose a finding/condition or the patient</obo:IAO_0000115>
        <oboInOwl:hasDbXref>biolink:Procedure</oboInOwl:hasDbXref>
        <rdfs:label>intervention</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/CLCO_0000103 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/CLCO_0000103">
        <oboInOwl:id>CLCO:0000103</oboInOwl:id>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/CLCO_0000100"/>
        <obo:IAO_0000115>Numerical or narrative temporal data elements</obo:IAO_0000115>
        <obo:IAO_0000232>Moved from subClassOf task (CLCO_0000109) to subClassOf clinical_entity (CLCO_0000100). Time is a first-class clinical entity type, not a subtype of task.</obo:IAO_0000232>
        <rdfs:label>time</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/CLCO_0000104 -->

