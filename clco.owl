    <!-- http://purl.obolibrary.org/obo/CLCO_0000002 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/CLCO_0000002">
        <oboInOwl:id>CLCO:0000002</oboInOwl:id>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/CLCO_0000058"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/CLCO_0002501"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CLCO_0000107"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/CLCO_0002502"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CLCO_0000110"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>Destination of patient transference</obo:IAO_0000115>
        <oboInOwl:hasDbXref>LOINC:LP203270-6</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>OMOP_CONCEPT_ID:1014654</oboInOwl:hasDbXref>
        <rdfs:label>is transferred to</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/CLCO_0000003 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/CLCO_0000003">
        <oboInOwl:id>CLCO:0000003</oboInOwl:id>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/CLCO_0000057"/>
        <obo:IAO_0000115>Clinical processes relation to administration.</obo:IAO_0000115>
        <obo:IAO_0000232>Do not instantiate.</obo:IAO_0000232>
        <rdfs:label>clinical administration</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/CLCO_0000005 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/CLCO_0000005">
        <oboInOwl:id>CLCO:0000005</oboInOwl:id>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/CLCO_0000057"/>
        <obo:IAO_0000115>A clinical association representing a decision made during patient care, such as a treatment plan, referral, or diagnostic strategy.</obo:IAO_0000115>
        <rdfs:label>clinical decision</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/CLCO_0000006 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/CLCO_0000006">
        <oboInOwl:id>CLCO:0000006</oboInOwl:id>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/CLCO_0000057"/>
        <obo:IAO_0000115>A clinical reason explaining the reasoning behind a treatment, intervention, condition or medical statement.</obo:IAO_0000115>
        <rdfs:label>clinical explanation</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/CLCO_0000007 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/CLCO_0000007">
        <oboInOwl:id>CLCO:0000007</oboInOwl:id>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/CLCO_0000003"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/CLCO_0002501"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/CLCO_0000102"/>
                            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/CLCO_0000109"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/CLCO_0002502"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CLCO_0000108"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000112>upload OSH CT chest pulmonary vein protocol</obo:IAO_0000112>
        <obo:IAO_0000115>A member of the clinical team has a specific action</obo:IAO_0000115>
        <oboInOwl:hasDbXref>OMOP_CONCEPT_ID:4044702</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>SNOMED:129450000</oboInOwl:hasDbXref>
        <rdfs:label>has action</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/CLCO_0000010 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/CLCO_0000010">
        <oboInOwl:id>CLCO:0000010</oboInOwl:id>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/CLCO_0000058"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/CLCO_0002501"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CLCO_0000107"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/CLCO_0002502"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CLCO_0000110"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000112>Patient admitted to ICU</obo:IAO_0000112>
        <obo:IAO_0000115>Statement indicating that the patient was admitted to a specific setting</obo:IAO_0000115>
        <obo:IAO_0000232>Does not exist in OMOP, admission is specific for inpatients or other facility types.</obo:IAO_0000232>
        <rdfs:label>is admitted</rdfs:label>
    </owl:Class>



    <!-- http://purl.obolibrary.org/obo/CLCO_0000114 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/CLCO_0000114">
        <oboInOwl:id>CLCO:0000114</oboInOwl:id>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/CLCO_0000058"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/CLCO_0002501"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CLCO_0000107"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/CLCO_0002502"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CLCO_0000110"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000112>Patient discharged this morning with family</obo:IAO_0000112>
        <obo:IAO_0000115>Statement indicating that the patient has been discharged from a clinical setting</obo:IAO_0000115>
        <oboInOwl:hasDbXref>OMOP_CONCEPT_ID:4137031</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>SNOMED:58000006</oboInOwl:hasDbXref>
        <rdfs:label>is discharged</rdfs:label>
    </owl:Class>



    <!-- http://purl.obolibrary.org/obo/CLCO_0000011 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/CLCO_0000011">
        <oboInOwl:id>CLCO:0000011</oboInOwl:id>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/CLCO_0000006"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/CLCO_0002501"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/CLCO_0000101"/>
                            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/CLCO_0000102"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/CLCO_0002502"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CLCO_0000102"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000112>Here for packing and splint removal after recent discharge from rehab</obo:IAO_0000112>
        <obo:IAO_0000115>Statement indicating that an intervention is followed by an intervention or assessment</obo:IAO_0000115>
        <obo:IAO_0000232>Used to be &quot;is followed by&quot; but this causes confusion when following refers to a particular clilnician responsible for a patient&apos;s care</obo:IAO_0000232>
