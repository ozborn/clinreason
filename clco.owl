<?xml version="1.0"?>
<rdf:RDF xmlns="http://purl.obolibrary.org/obo/clco.owl#"
     xml:base="http://purl.obolibrary.org/obo/clco.owl"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:obo="http://purl.obolibrary.org/obo/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:terms="http://purl.org/dc/terms/"
     xmlns:oboInOwl="http://www.geneontology.org/formats/oboInOwl#">
    <owl:Ontology rdf:about="http://purl.obolibrary.org/obo/clco.owl">
        <owl:versionIRI rdf:resource="http://purl.obolibrary.org/obo/clco/releases/2025-09-05/clco.owl"/>
        <dc:description>An ontology for representing clinical reasoning context, including diagnostic workflows, therapeutic decision-making, and the clinician interpretations and decisions that surround patient care but are not well captured by problem-focused EHR systems or terminologies such as SNOMED CT.</dc:description>
        <dc:title>Clinical Context Ontology</dc:title>
        <dc:creator>Tiago K. Colicchio</dc:creator>
        <dc:creator>James J. Cimino</dc:creator>
        <dc:creator>John D. Osborne</dc:creator>
        <terms:creator rdf:resource="https://orcid.org/0000-0003-3405-1538"/>
        <terms:creator rdf:resource="https://orcid.org/0000-0003-4101-1622"/>
        <terms:creator rdf:resource="https://orcid.org/0000-0002-0851-1150"/>
        <terms:license rdf:resource="http://creativecommons.org/licenses/by/4.0/"/>
        <owl:versionInfo>2025-09-05</owl:versionInfo>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://purl.obolibrary.org/obo/BFO_0000001 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/BFO_0000001">
        <obo:IAO_0000115>An entity is anything that exists or has existed or will exist.</obo:IAO_0000115>
        <rdfs:label>entity</rdfs:label>
    </owl:Class>


    <!-- http://purl.obolibrary.org/obo/IAO_0000030 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/IAO_0000030">
        <obo:IAO_0000115>A generically dependent continuant that is about some entity.</obo:IAO_0000115>
        <rdfs:label>information content entity</rdfs:label>
    </owl:Class>


    <!-- http://purl.obolibrary.org/obo/IAO_0000112 -->

    <owl:AnnotationProperty rdf:about="http://purl.obolibrary.org/obo/IAO_0000112"/>
    


    <!-- http://purl.obolibrary.org/obo/IAO_0000115 -->

    <owl:AnnotationProperty rdf:about="http://purl.obolibrary.org/obo/IAO_0000115"/>
    


    <!-- http://purl.obolibrary.org/obo/IAO_0000116 -->

    <owl:AnnotationProperty rdf:about="http://purl.obolibrary.org/obo/IAO_0000116"/>
    


    <!-- http://purl.obolibrary.org/obo/IAO_0000232 -->

    <owl:AnnotationProperty rdf:about="http://purl.obolibrary.org/obo/IAO_0000232"/>
    


    <!-- http://purl.obolibrary.org/obo/RO_0001900 -->

    <owl:AnnotationProperty rdf:about="http://purl.obolibrary.org/obo/RO_0001900">
        <obo:IAO_0000115>Indicates whether a relation holds at all times or some times during the existence of the subject and object.</obo:IAO_0000115>
        <rdfs:label>temporal interpretation</rdfs:label>
    </owl:AnnotationProperty>
    


    <!-- http://purl.org/dc/elements/1.1/description -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/description"/>
    


    <!-- http://purl.org/dc/elements/1.1/title -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/title"/>
    


    <!-- http://purl.org/dc/terms/description -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/description"/>
    


    <!-- http://purl.org/dc/terms/license -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/license"/>
    


    <!-- http://purl.org/dc/terms/title -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/title"/>
    


    <!-- http://www.geneontology.org/formats/oboInOwl#hasDbXref -->

    <owl:AnnotationProperty rdf:about="http://www.geneontology.org/formats/oboInOwl#hasDbXref"/>
    


    <!-- http://www.geneontology.org/formats/oboInOwl#id -->

    <owl:AnnotationProperty rdf:about="http://www.geneontology.org/formats/oboInOwl#id"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Datatypes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.w3.org/2001/XMLSchema#duration -->

    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#duration"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://purl.obolibrary.org/obo/CLCO_0002000 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/CLCO_0002000">
        <oboInOwl:id>CLCO:0002000</oboInOwl:id>
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/CLCO_0000057"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/CLCO_0000067"/>
        <obo:IAO_0000115>A modifier of a clinical association</obo:IAO_0000115>
        <rdfs:label>has association qualifier</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/CLCO_0002002 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/CLCO_0002002">
        <oboInOwl:id>CLCO:0002002</oboInOwl:id>
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/CLCO_0003000"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/CLCO_0000060"/>
        <obo:IAO_0000115>Relates a clinical association to its intention qualifier, indicating that the association is intended rather than actual.</obo:IAO_0000115>
        <rdfs:label>has intention</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/CLCO_0002003 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/CLCO_0002003">
        <oboInOwl:id>CLCO:0002003</oboInOwl:id>
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/CLCO_0003000"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/CLCO_0000062"/>
        <obo:IAO_0000115>Relates a clinical association to its recommendation qualifier, indicating that the association represents a clinical recommendation.</obo:IAO_0000115>
        <rdfs:label>has recommended</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/CLCO_0002004 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/CLCO_0002004">
        <oboInOwl:id>CLCO:0002004</oboInOwl:id>
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/CLCO_0002000"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/CLCO_0000080"/>
        <obo:IAO_0000115>Relates a clinical association to its negation status, indicating whether the asserted relationship is negated.</obo:IAO_0000115>
        <rdfs:label>has negation status</rdfs:label>
    </owl:ObjectProperty>
    




    <!-- http://purl.obolibrary.org/obo/CLCO_0002009 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/CLCO_0002009">
        <oboInOwl:id>CLCO:0002009</oboInOwl:id>
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/CLCO_0002000"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/CLCO_0000081"/>
        <obo:IAO_0000115>Relates a clinical association to its uncertainty qualifier, indicating that the asserted relationship is uncertain or suspected.</obo:IAO_0000115>
        <rdfs:label>has uncertainty status</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/CLCO_0002100 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/CLCO_0002100">
        <oboInOwl:id>CLCO:0002100</oboInOwl:id>
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/CLCO_0002000"/>
        <obo:IAO_0000115>Relates a clinical association to a qualifier that modifies a participant (subject or object) rather than the overall statement or predicate.</obo:IAO_0000115>
        <rdfs:label>has participant qualifier</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/CLCO_0002500 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/CLCO_0002500">
        <oboInOwl:id>CLCO:0002500</oboInOwl:id>
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <obo:IAO_0000115>Relates a clinical association to a clinical entity that participates in it as either the subject or the object.</obo:IAO_0000115>
        <rdfs:label>has association participant</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/CLCO_0002501 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/CLCO_0002501">
        <oboInOwl:id>CLCO:0002501</oboInOwl:id>
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/CLCO_0002500"/>
        <obo:IAO_0000115>Relates a clinical association (an asserted statement) to the entity that occupies the object position in that association.</obo:IAO_0000115>
        <rdfs:label>has object</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/CLCO_0002502 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/CLCO_0002502">
        <oboInOwl:id>CLCO:0002502</oboInOwl:id>
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/CLCO_0002500"/>
        <obo:IAO_0000115>Relates a clinical association (an asserted statement) to the entity that occupies the subject position in that association.</obo:IAO_0000115>
        <rdfs:label>has subject</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/CLCO_0002603 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/CLCO_0002603">
        <oboInOwl:id>CLCO:0002603</oboInOwl:id>
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/CLCO_0002000"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/CLCO_0000082"/>
        <obo:IAO_0000115>Relates a clinical association to its temporal frame value (historical, current, future, or hypothetical) indicating when the association holds relative to the clinical document.</obo:IAO_0000115>
        <obo:RO_0001900 rdf:resource="http://purl.obolibrary.org/obo/RO_0001901"/>
        <oboInOwl:hasDbXref>biolink:temporal_context_qualifier</oboInOwl:hasDbXref>
        <rdfs:label>has temporal frame</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/CLCO_0002604 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/CLCO_0002604">
        <oboInOwl:id>CLCO:0002604</oboInOwl:id>
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/CLCO_0003000"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/CLCO_0000063"/>
        <obo:IAO_0000115>Relates a clinical association to its workflow completion status (pending, in_progress, or completed). Orthogonal to temporal frame and intention.</obo:IAO_0000115>
        <obo:IAO_0000232>Not a sub-property of has_temporal_context because completion status is not a temporal concept. A pending process may be temporally past (labs drawn yesterday, results pending).</obo:IAO_0000232>
        <obo:RO_0001900 rdf:resource="http://purl.obolibrary.org/obo/RO_0001901"/>
        <rdfs:label>has completion status</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/CLCO_0003000 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/CLCO_0003000">
        <oboInOwl:id>CLCO:0003000</oboInOwl:id>
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/CLCO_0002000"/>
        <obo:IAO_0000115>Relates a clinical association to a statement-level qualifier that modifies the entire assertion, such as intention, recommendation, or completion status.</obo:IAO_0000115>
        <rdfs:label>has statement qualifier</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://purl.obolibrary.org/obo/CLCO_0002700 -->

    <owl:DatatypeProperty rdf:about="http://purl.obolibrary.org/obo/CLCO_0002700">
        <oboInOwl:id>CLCO:0002700</oboInOwl:id>
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/CLCO_0000057"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <obo:IAO_0000115>The point in time at which the clinical association begins to hold.</obo:IAO_0000115>
        <obo:IAO_0000232>Complements (does not replace) the reified temporal association has_onset (CLCO_0000022). Use this data property for computable timestamps from structured EHR data or normalized NLP output; use has_onset when the temporal expression itself is extracted from narrative text and needs its own qualifiers.</obo:IAO_0000232>
        <rdfs:label>has start time</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://purl.obolibrary.org/obo/CLCO_0002701 -->

    <owl:DatatypeProperty rdf:about="http://purl.obolibrary.org/obo/CLCO_0002701">
        <oboInOwl:id>CLCO:0002701</oboInOwl:id>
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/CLCO_0000057"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <obo:IAO_0000115>The point in time at which the clinical association ceases to hold.</obo:IAO_0000115>
        <rdfs:label>has end time</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://purl.obolibrary.org/obo/CLCO_0002702 -->

    <owl:DatatypeProperty rdf:about="http://purl.obolibrary.org/obo/CLCO_0002702">
        <oboInOwl:id>CLCO:0002702</oboInOwl:id>
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/CLCO_0000057"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#duration"/>
        <obo:IAO_0000115>The ISO 8601 duration for which the clinical association holds.</obo:IAO_0000115>
        <obo:IAO_0000232>Complements (does not replace) the reified temporal association has_duration (CLCO_0000053). Use this data property for computable duration values; use has_duration when the duration expression needs its own qualifiers.</obo:IAO_0000232>
        <rdfs:label>has duration value</rdfs:label>
    </owl:DatatypeProperty>
    


