    <!-- http://purl.obolibrary.org/obo/CLCO_0000055 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/CLCO_0000055">
        <oboInOwl:id>CLCO:0000055</oboInOwl:id>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/CLCO_0000025"/>
        <rdfs:subClassOf>
